# docs/env.md と対応。これをコピーして .env を作る（.env はコミットしない）。

# 待受ポート（Railway が注入）
PORT=8000

# SQLite・画像・キャッシュの置き場。本番は /data（ボリューム）
DATA_DIR=./data

# 埋め込み ONNX。無ければ predict/label は 503 を返す（起動はする）
MODEL_PATH=models/dinov2_vits14.onnx
MODEL_NAME=dinov2_vits14
EMBED_VERSION=1

# k-NN
KNN_K=9
UNCERTAIN_THRESHOLD=0.55

# 画像
MAX_IMAGE_BYTES=10485760
ALLOW_IMAGE_URL=false

# admin Basic 認証（必須）
ADMIN_USER=admin
ADMIN_PASS=change-me

# ローカル開発専用。本番では絶対 true にしない
AUTH_DISABLED=false

# 任意
# DEFAULT_PROJECT=
LOG_LEVEL=info
